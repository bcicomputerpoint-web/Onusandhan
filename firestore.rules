rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: checks token email or the stored role in user document
    function isAdmin() { 
      let isEmailAdmin = isSignedIn() && (
        request.auth.token.email == 'bcicomputerpoint@gmail.com' ||
        request.auth.token.email == 'admin@onusandhan.com'
      );
      // Fallback to Firestore check if email isn't in hardcoded list
      return isEmailAdmin || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin');
    }

    // ----------------------------------------------------
    // COLLECTION GROUPS (For Admin Global Views)
    // ----------------------------------------------------
    match /{path=**}/drive_items/{itemId} {
      allow list: if isAdmin();
    }

    // ----------------------------------------------------
    // USERS COLLECTION
    // ----------------------------------------------------
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'role', 'createdAt'])
          && data.email is string && data.email.size() <= 100
          && data.role in ['Admin', 'Scholar', 'Student', 'Centre']
          && data.createdAt is number;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && (isOwner(userId) || isAdmin())
        && isValidUser(incoming())
        // Prevent self-elevation to Admin
        && (incoming().role != 'Admin' || request.auth.token.email == 'bcicomputerpoint@gmail.com');

      allow update: if (isOwner(userId) || isAdmin())
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Update Role (Scholars can change between valid roles except Admin)
          (incoming().diff(existing()).affectedKeys().hasOnly(['role']) && 
           (incoming().role in ['Scholar', 'Student', 'Centre'] || isAdmin()))
        );

      allow delete: if isAdmin();

      // ----------------------------------------------------
      // PROFILE SUBCOLLECTION (users/{userId}/profile/info)
      // ----------------------------------------------------
      match /profile/info {
        function isValidProfile(data) {
          return data.keys().hasAll(['full_name'])
            && data.full_name is string && data.full_name.size() <= 100
            && (!('photo_url' in data) || (data.photo_url is string && data.photo_url.size() <= 1000))
            && (!('institution' in data) || (data.institution is string && data.institution.size() <= 200))
            && (!('department' in data) || (data.department is string && data.department.size() <= 200))
            && (!('research_area' in data) || (data.research_area is string && data.research_area.size() <= 200))
            && (!('mobile' in data) || (data.mobile is string && data.mobile.size() <= 20))
            && (!('full_name_lower' in data) || (data.full_name_lower is string && data.full_name_lower.size() <= 100));
        }

        allow get: if isOwner(userId) || isAdmin();
        allow create, update: if (isOwner(userId) || isAdmin()) && isValidId(userId) && isValidProfile(incoming());
        allow delete: if isAdmin();
      }

      // ----------------------------------------------------
      // DRIVE ITEMS SUBCOLLECTION (users/{userId}/drive_items/{itemId})
      // ----------------------------------------------------
      match /drive_items/{itemId} {
        function isValidDriveItem(data) {
          return data.keys().hasAll(['title', 'item_type', 'category', 'user_id', 'created_at', 'visibility'])
            && data.title is string && data.title.size() <= 256
            && data.item_type in ['Document', 'Link']
            && data.category is string && data.category.size() <= 128
            && data.user_id == userId
            && data.created_at is number
            && data.visibility in ['Private', 'Public']
            && (!('file_path' in data) || (data.file_path is string && data.file_path.size() <= 2048))
            && (!('external_url' in data) || (data.external_url is string && data.external_url.size() <= 2048))
            && (!('abstract' in data) || (data.abstract is string && data.abstract.size() <= 4096));
        }

        // Secure List Query: Enforce owner constraint for listings
        allow list: if isOwner(userId) || isAdmin();
        
        allow get: if isOwner(userId) || existing().visibility == 'Public' || isAdmin();
        
        allow create: if (isOwner(userId) || isAdmin()) 
          && isValidId(itemId)
          && isValidDriveItem(incoming());

        allow update: if (isOwner(userId) || isAdmin())
          && isValidDriveItem(incoming())
          && incoming().user_id == existing().user_id
          && incoming().created_at == existing().created_at
          && (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'visibility', 'abstract', 'file_path', 'external_url']) || isAdmin());

        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // ----------------------------------------------------
    // LMS COLLECTIONS
    // ----------------------------------------------------
    
    // Courses Collection
    match /courses/{courseId} {
      function isValidCourse(data) {
        return data.keys().hasAll(['title', 'instructor_id', 'level', 'created_at'])
          && data.title is string && data.title.size() <= 200
          && data.instructor_id is string
          && data.level in ['School', 'College', 'PhD']
          && data.created_at is number;
      }

      allow read: if isSignedIn();
      allow create: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Centre')) && isValidCourse(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().instructor_id == request.auth.uid)) && isValidCourse(incoming());
      allow delete: if isAdmin();

      // Lessons Sub-collection
      match /lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructor_id == request.auth.uid);
      }
      
      // Assignments Sub-collection
      match /assignments/{assignmentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructor_id == request.auth.uid);
      }
    }

    // Enrollments Collection
    match /enrollments/{enrollmentId} {
      function isValidEnrollment(data) {
        return data.keys().hasAll(['user_id', 'course_id', 'enrolled_at', 'status'])
          && data.user_id == request.auth.uid
          && data.course_id is string
          && data.enrolled_at is number
          && data.status in ['Active', 'Completed'];
      }
      
      allow list: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow get: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidEnrollment(incoming());
      allow update: if (isSignedIn() && existing().user_id == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Submissions Collection
    match /submissions/{submissionId} {
      function isValidSubmission(data) {
        return data.keys().hasAll(['assignment_id', 'course_id', 'user_id', 'user_name', 'submission_url', 'submitted_at', 'status', 'grade'])
          && data.user_id == request.auth.uid
          && data.assignment_id is string
          && data.course_id is string
          && data.submission_url is string
          && data.status == 'Submitted';
      }

      allow list: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow get: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidSubmission(incoming());
      allow update: if isAdmin(); // Only admins can grade
      allow delete: if isAdmin();
    }
  }
}

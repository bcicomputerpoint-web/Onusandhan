{
  "entities": {
    "User": {
      "title": "User Account",
      "description": "Core user account information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Scholar", "Student", "Centre"] },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Profile": {
      "title": "User Profile",
      "description": "Public and private profile details for academic identity",
      "type": "object",
      "properties": {
        "full_name": { "type": "string" },
        "photo_url": { "type": "string" },
        "institution": { "type": "string" },
        "department": { "type": "string" },
        "research_area": { "type": "string" },
        "mobile": { "type": "string" }
      },
      "required": ["full_name"]
    },
    "DriveItem": {
      "title": "Drive Item",
      "description": "Documents or links managed by the user",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "item_type": { "type": "string", "enum": ["Document", "Link"] },
        "category": { "type": "string" },
        "file_path": { "type": "string" },
        "external_url": { "type": "string" },
        "abstract": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "number" },
        "visibility": { "type": "string", "enum": ["Private", "Public"] }
      },
      "required": ["title", "item_type", "category", "user_id", "created_at", "visibility"]
    },
    "Course": {
      "title": "Academic Course",
      "description": "Educational course offered on the platform",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructor_id": { "type": "string" },
        "thumbnail_url": { "type": "string" },
        "category": { "type": "string" },
        "level": { "type": "string", "enum": ["School", "College", "PhD"] },
        "created_at": { "type": "number" }
      },
      "required": ["title", "instructor_id", "level", "created_at"]
    },
    "Lesson": {
      "title": "Course Lesson",
      "description": "Specific instructional unit within a module",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content_type": { "type": "string", "enum": ["Video", "PDF", "Quiz"] },
        "content_url": { "type": "string" },
        "duration_mins": { "type": "number" },
        "order": { "type": "number" }
      },
      "required": ["title", "content_type", "order"]
    },
    "Assignment": {
      "title": "Academic Assignment",
      "description": "Task for students to complete and submit",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "due_date": { "type": "number" },
        "max_points": { "type": "number" },
        "course_id": { "type": "string" }
      },
      "required": ["title", "due_date", "course_id"]
    },
    "Enrollment": {
      "title": "Course Enrollment",
      "description": "Subscription of a student to a course",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "course_id": { "type": "string" },
        "progress": { "type": "number" },
        "enrolled_at": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Completed"] }
      },
      "required": ["user_id", "course_id", "enrolled_at", "status"]
    },
    "Submission": {
      "title": "Assignment Submission",
      "description": "Student work submitted for an assignment",
      "type": "object",
      "properties": {
        "assignment_id": { "type": "string" },
        "course_id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "submission_url": { "type": "string" },
        "submitted_at": { "type": "number" },
        "status": { "type": "string", "enum": ["Submitted", "Graded"] },
        "grade": { "type": "number" }
      },
      "required": ["assignment_id", "course_id", "user_id", "submission_url", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Base user document"
    },
    "/users/{userId}/profile/info": {
      "schema": "Profile",
      "description": "Single profile info document"
    },
    "/users/{userId}/drive_items/{itemId}": {
      "schema": "DriveItem",
      "description": "List of user docs and links"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Top-level course metadata"
    },
    "/courses/{courseId}/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons organized within a course"
    },
    "/courses/{courseId}/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Assignments directly under a course"
    },
    "/enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "Relationship between users and courses"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Student work records"
    }
  }
}

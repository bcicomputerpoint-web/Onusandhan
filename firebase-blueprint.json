{
  "entities": {
    "User": {
      "title": "User Account",
      "description": "Core user account information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "password_hash": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Scholar", "Student", "Centre"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "password_hash", "role", "created_at"]
    },
    "Profile": {
      "title": "User Profile",
      "description": "Public and private profile details for academic identity",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "full_name": { "type": "string" },
        "institution": { "type": "string" },
        "department": { "type": "string" },
        "research_area": { "type": "string" },
        "orcid": { "type": "string" },
        "bio": { "type": "string" },
        "session": { "type": "string" },
        "university": { "type": "string" },
        "program": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "full_name"]
    },
    "DriveItem": {
      "title": "Drive Item",
      "description": "Documents or links managed by the user",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "item_type": { "type": "string", "enum": ["Document", "Link"] },
        "category": { "type": "string" },
        "authors": { "type": "string" },
        "abstract": { "type": "string" },
        "publish_year": { "type": "number" },
        "file_path": { "type": "string" },
        "external_url": { "type": "string" },
        "visibility": { "type": "string", "enum": ["Private", "Public"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "title", "item_type", "category", "created_at", "visibility"]
    },
    "Course": {
      "title": "Academic Course",
      "description": "Educational course offered on the platform",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructor_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "instructor_id", "created_at"]
    },
    "Lesson": {
      "title": "Course Lesson",
      "description": "Specific instructional unit within a module",
      "type": "object",
      "properties": {
        "course_id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "video_url": { "type": "string" },
        "order_index": { "type": "number" }
      },
      "required": ["course_id", "title", "order_index"]
    },
    "Assignment": {
      "title": "Academic Assignment",
      "description": "Task for students to complete and submit",
      "type": "object",
      "properties": {
        "course_id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "due_date": { "type": "string", "format": "date-time" }
      },
      "required": ["course_id", "title"]
    },
    "Enrollment": {
      "title": "Course Enrollment",
      "description": "Subscription of a student to a course",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "course_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "course_id", "created_at"]
    },
    "Submission": {
      "title": "Assignment Submission",
      "description": "Student work submitted for an assignment",
      "type": "object",
      "properties": {
        "assignment_id": { "type": "string" },
        "user_id": { "type": "string" },
        "file_path": { "type": "string" },
        "submitted_at": { "type": "string", "format": "date-time" },
        "feedback": { "type": "string" },
        "grade": { "type": "string" }
      },
      "required": ["assignment_id", "user_id", "submitted_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Base user document"
    },
    "/profiles/{profileId}": {
      "schema": "Profile",
      "description": "User profile details indexed by user_id or random ID"
    },
    "/drive_items/{itemId}": {
      "schema": "DriveItem",
      "description": "List of user docs and links"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Top-level course metadata"
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons organized within a course"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Assignments directly under a course"
    },
    "/enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "Relationship between users and courses"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Student work records"
    }
  }
}
